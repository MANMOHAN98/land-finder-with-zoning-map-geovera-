rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Since our system uses a full-stack architecture where all database requests
    // are proxied, validated, and serialized through the server API, we allow 
    // access to these specific collections.
    
    match /users/{userId} {
      allow read, write: if true;
    }

    match /listings/{listingId} {
      allow read, write: if true;
    }

    match /messages/{messageId} {
      allow read, write: if true;
    }

    match /logs/{logId} {
      allow read, write: if true;
    }
  }
}
